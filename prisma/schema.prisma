datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ----------------------------------------------------
// 1. USUÁRIOS E CONTROLE DE ACESSO
// ----------------------------------------------------

enum UserRole {
  SUPER_ADMIN // Administrador global da plataforma (Match Barber)
  USER        // Cliente final que agenda horários
}

model User {
  id            String             @id @default(uuid())
  name          String
  email         String?            @unique // Opcional para clientes, obrigatório para staff/admin
  phone         String             @unique // Obrigatório e único para todos (chave de login do cliente)
  cpf           String?            @unique // Opcional para clientes, obrigatório para staff/admin
  passwordHash  String?            @map("password_hash") // Opcional para clientes (login sem senha)
  role          UserRole           @default(USER)
  avatarUrl     String?            @map("avatar_url")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  // Relacionamentos
  memberships   BarbershopMember[] // Caso o usuário seja funcionário/dono de barbearia
  appointments  Appointment[]      // Histórico de agendamentos como cliente
  reviews       Review[]           // Avaliações feitas pelo cliente
  notifications Notification[]
  comandas      Comanda[]

  @@map("users")
}

// ----------------------------------------------------
// 2. TENANTS (ESTABELECIMENTOS / BARBEARIAS)
// ----------------------------------------------------

model Barbershop {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique // Para URLs amigáveis: matchbarber.com.br/barbearia-do-ze
  logoUrl     String?  @map("logo_url")
  coverUrl    String?  @map("cover_url")
  description String?
  phone       String
  active      Boolean  @default(true)

  // Endereço
  zipCode      String   @map("zip_code")
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  latitude     Float?
  longitude    Float?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relacionamentos
  members       BarbershopMember[]
  services      Service[]
  categories    Category[]
  appointments  Appointment[]
  subscriptions TenantSubscription[]
  idempotencyKeys IdempotencyKey[]
  comandas      Comanda[]
  products      Product[]
  cashSessions  CashSession[]
  financialEntries FinancialEntry[]
  commissionConfigs CommissionConfig[]
  commissionEntries CommissionEntry[]
  commissionPeriods CommissionPeriod[]
  commissionAdjustments CommissionAdjustment[]

  @@map("barbershops")
}

model IdempotencyKey {
  id           String   @id @default(uuid())
  barbershopId String   @map("barbershop_id")
  key          String
  requestHash  String   @map("request_hash")
  result       Json?
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([barbershopId, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// Papéis dentro de uma barbearia específica
enum MemberRole {
  OWNER   // Dono da barbearia (acesso total administrativo)
  MANAGER // Gerente (acesso operacional e financeiro básico)
  BARBER  // Barbeiro / Colaborador (vê apenas a própria agenda)
}

model BarbershopMember {
  id           String     @id @default(uuid())
  barbershopId String     @map("barbershop_id")
  userId       String     @map("user_id")
  role         MemberRole @default(BARBER)
  bio          String?
  ratingAvg    Float      @default(0.0) @map("rating_avg")
  isActive     Boolean    @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relacionamentos
  barbershop   Barbershop      @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  services     BarberService[]
  workingHours WorkingHour[]
  timeOffs     TimeOff[]
  appointments Appointment[]
  comandaItems  ComandaItem[]
  commissionConfigs CommissionConfig[]
  commissionEntries CommissionEntry[]
  commissionPeriods CommissionPeriod[]
  commissionAdjustments CommissionAdjustment[]

  @@unique([barbershopId, userId])
  @@map("barbershop_members")
}

// ----------------------------------------------------
// 3. CATEGORIAS E SERVIÇOS
// ----------------------------------------------------

model Category {
  id           String @id @default(uuid())
  barbershopId String @map("barbershop_id")
  name         String
  slug         String

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  services   Service[]
  commissionConfigs CommissionConfig[]

  @@unique([barbershopId, slug])
  @@map("categories")
}

model Service {
  id           String  @id @default(uuid())
  barbershopId String  @map("barbershop_id")
  categoryId   String  @map("category_id")
  name         String
  description  String?
  price        Decimal @db.Decimal(10, 2)
  durationMin  Int     @map("duration_min") // Duração do serviço em minutos
  isActive     Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relacionamentos
  barbershop   Barbershop           @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  category     Category             @relation(fields: [categoryId], references: [id])
  barbers      BarberService[]
  appointments AppointmentService[]
  comandaItems ComandaItem[]
  commissionConfigs CommissionConfig[]

  @@map("services")
}

// Tabela dinâmica de associação N:N entre Barbeiro e Serviço
model BarberService {
  barberId  String @map("barber_id")
  serviceId String @map("service_id")

  barber  BarbershopMember @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([barberId, serviceId])
  @@map("barber_services")
}

// ----------------------------------------------------
// 4. AGENDAS E HORÁRIOS
// ----------------------------------------------------

// Grade de horários padrão de trabalho do profissional (Ex: Seg a Sex, 09:00 às 18:00)
model WorkingHour {
  id         String  @id @default(uuid())
  memberId   String  @map("member_id")
  dayOfWeek  Int     @map("day_of_week") // 0 = Domingo, 1 = Segunda, ..., 6 = Sábado
  startTime  String  @map("start_time") // Formato "HH:MM"
  endTime    String  @map("end_time")   // Formato "HH:MM"

  // Horários de Intervalo (Almoço/Pausa)
  breakStart String? @map("break_start") // Formato "HH:MM"
  breakEnd   String? @map("break_end")   // Formato "HH:MM"
  isActive   Boolean @default(true) @map("is_active")

  member BarbershopMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, dayOfWeek])
  @@map("working_hours")
}

// Dias de folga, férias ou bloqueios temporários de agenda de um profissional
model TimeOff {
  id        String   @id @default(uuid())
  memberId  String   @map("member_id")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  reason    String?  // Ex: "Férias", "Médico", "Bloqueio manual"

  member BarbershopMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("time_offs")
}

// ----------------------------------------------------
// 5. AGENDAMENTOS E FLUXO
// ----------------------------------------------------

enum AppointmentStatus {
  PENDING    // Aguardando confirmação (caso a barbearia use aprovação manual)
  CONFIRMED  // Confirmado e ativo
  COMPLETED  // Serviço finalizado com sucesso
  CANCELLED  // Cancelado pelo cliente ou estabelecimento
  NO_SHOW    // Cliente não compareceu
}

model Appointment {
  id           String            @id @default(uuid())
  barbershopId String            @map("barbershop_id")
  memberId     String            @map("member_id") // O barbeiro que executará o serviço
  customerId   String            @map("customer_id") // O cliente que reservou
  dateTime     DateTime          @map("date_time") // Data e hora de início do atendimento
  totalPrice   Decimal           @map("total_price") @db.Decimal(10, 2)
  durationMin  Int               @map("duration_min") // Soma das durações dos serviços escolhidos
  status       AppointmentStatus @default(CONFIRMED)
  notes        String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relacionamentos
  barbershop Barbershop           @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barber     BarbershopMember     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  customer   User                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  services   AppointmentService[]
  review     Review?
  comandas   Comanda[]

  @@index([barbershopId, dateTime])
  @@index([memberId, dateTime])
  @@map("appointments")
}

// Serviços atrelados ao agendamento (suporta múltiplos serviços no mesmo slot)
model AppointmentService {
  appointmentId String  @map("appointment_id")
  serviceId     String  @map("service_id")
  priceApplied  Decimal @map("price_applied") @db.Decimal(10, 2) // Salva o preço cobrado na época

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])

  @@id([appointmentId, serviceId])
  @@map("appointment_services")
}

// ----------------------------------------------------
// 6. AVALIAÇÕES E COMUNICAÇÃO
// ----------------------------------------------------

model Review {
  id            String   @id @default(uuid())
  appointmentId String   @unique @map("appointment_id")
  customerId    String   @map("customer_id")
  rating        Int      // 1 a 5 estrelas
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customer    User        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  title     String
  content   String
  type      String    // "APPOINTMENT_REMINDER", "APPOINTMENT_CONFIRMED", "SYSTEM_ALERT"
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ----------------------------------------------------
// 7. ASSINATURA DA PLATAFORMA (SAAS) E FINANCEIRO
// ----------------------------------------------------

enum PlanPeriod {
  MONTHLY
  YEARLY
}

model Plan {
  id          String     @id @default(uuid())
  name        String     // Ex: "Bronze", "Prata", "Ouro"
  description String?
  price       Decimal    @db.Decimal(10, 2)
  period      PlanPeriod @default(MONTHLY)
  maxMembers  Int        @map("max_members") // Limite de barbeiros por plano
  isActive    Boolean    @default(true) @map("is_active")

  subscriptions TenantSubscription[]

  @@map("plans")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  SUSPENDED
}

model TenantSubscription {
  id                 String             @id @default(uuid())
  barbershopId       String             @map("barbershop_id")
  planId             String             @map("plan_id")
  status             SubscriptionStatus @default(TRIAL)
  planName           String?            @map("plan_name")
  monthlyPrice       Decimal?           @map("monthly_price") @db.Decimal(10, 2)
  trialEndsAt        DateTime?          @map("trial_ends_at")
  currentPeriodStart DateTime           @map("period_start")
  currentPeriodEnd   DateTime           @map("period_end")
  gracePeriodEndsAt  DateTime?          @map("grace_period_ends_at")
  paymentMethod      String?            @map("payment_method")
  lastPaymentAt      DateTime?          @map("last_payment_at")
  internalNotes      String?            @map("internal_notes")
  updatedBy          String?            @map("updated_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  plan       Plan       @relation(fields: [planId], references: [id])

  @@map("tenant_subscriptions")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CommandPaymentStatus {
  CONFIRMED
  REFUNDED
}

enum ComandaStatus {
  OPEN
  IN_SERVICE
  PENDING_PAYMENT
  CLOSED
  CANCELLED
}

enum ComandaItemType {
  SERVICE
  PRODUCT
  DISCOUNT
  SURCHARGE
}

enum ComandaItemStatus {
  PENDING
  DONE
  CANCELLED
}

enum PaymentMethod {
  CASH
  PIX
  DEBIT
  CREDIT
  OTHER
}

enum StockMovementType {
  SALE
  REFUND
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum FinancialEntryType {
  COMMAND_REVENUE
  REFUND
  MANUAL_IN
  MANUAL_OUT
}

model Comanda {
  id             String        @id @default(uuid())
  barbershopId   String        @map("barbershop_id")
  appointmentId  String?       @unique @map("appointment_id")
  customerId     String?       @map("customer_id")
  customerName   String        @map("customer_name")
  customerPhone  String?       @map("customer_phone")
  status         ComandaStatus @default(OPEN)
  subtotal       Decimal       @default(0) @db.Decimal(10, 2)
  discountTotal  Decimal       @default(0) @map("discount_total") @db.Decimal(10, 2)
  surchargeTotal Decimal       @default(0) @map("surcharge_total") @db.Decimal(10, 2)
  total          Decimal       @default(0) @db.Decimal(10, 2)
  paidTotal      Decimal       @default(0) @map("paid_total") @db.Decimal(10, 2)
  remainingTotal Decimal       @default(0) @map("remaining_total") @db.Decimal(10, 2)
  openedAt       DateTime      @default(now()) @map("opened_at")
  startedAt      DateTime?     @map("started_at")
  closedAt       DateTime?     @map("closed_at")
  cancelledAt    DateTime?     @map("cancelled_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  barbershop  Barbershop   @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  customer    User?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items       ComandaItem[]
  payments    Payment[]

  @@index([barbershopId, status])
  @@index([barbershopId, openedAt])
  @@map("comandas")
}

model ComandaItem {
  id              String            @id @default(uuid())
  comandaId        String            @map("comanda_id")
  barbershopId     String            @map("barbershop_id")
  type            ComandaItemType
  status          ComandaItemStatus @default(PENDING)
  description     String
  quantity        Decimal           @default(1) @db.Decimal(10, 3)
  unitPrice       Decimal           @map("unit_price") @db.Decimal(10, 2)
  discountAmount  Decimal           @default(0) @map("discount_amount") @db.Decimal(10, 2)
  surchargeAmount Decimal           @default(0) @map("surcharge_amount") @db.Decimal(10, 2)
  total           Decimal           @db.Decimal(10, 2)
  serviceId       String?           @map("service_id")
  productId       String?           @map("product_id")
  executorId      String?           @map("executor_id")
  completedAt     DateTime?         @map("completed_at")
  cancelledAt     DateTime?         @map("cancelled_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  comanda   Comanda           @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  service   Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  product   Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  executor  BarbershopMember? @relation(fields: [executorId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]
  commissionEntry CommissionEntry?

  @@index([barbershopId, comandaId])
  @@index([executorId, status])
  @@map("comanda_items")
}

model Product {
  id             String   @id @default(uuid())
  barbershopId   String   @map("barbershop_id")
  name           String
  description    String?
  salePrice      Decimal  @map("sale_price") @db.Decimal(10, 2)
  costPrice      Decimal? @map("cost_price") @db.Decimal(10, 2)
  unit           String   @default("un")
  isActive       Boolean  @default(true) @map("is_active")
  trackStock     Boolean  @default(false) @map("track_stock")
  currentStock   Decimal  @default(0) @map("current_stock") @db.Decimal(10, 3)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  items      ComandaItem[]
  movements  StockMovement[]

  @@index([barbershopId, isActive])
  @@map("products")
}

model StockMovement {
  id            String            @id @default(uuid())
  barbershopId  String            @map("barbershop_id")
  productId     String            @map("product_id")
  comandaItemId String?           @map("comanda_item_id")
  type          StockMovementType
  quantity      Decimal           @db.Decimal(10, 3)
  description   String?
  createdAt     DateTime          @default(now()) @map("created_at")

  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  comandaItem ComandaItem? @relation(fields: [comandaItemId], references: [id], onDelete: SetNull)

  @@index([barbershopId, productId, createdAt])
  @@map("stock_movements")
}

model Payment {
  id            String        @id @default(uuid())
  barbershopId  String        @map("barbershop_id")
  comandaId     String        @map("comanda_id")
  method        PaymentMethod
  amount        Decimal       @db.Decimal(10, 2)
  status        CommandPaymentStatus @default(CONFIRMED)
  idempotencyKey String?      @map("idempotency_key")
  paidAt        DateTime      @default(now()) @map("paid_at")
  receivedById  String?       @map("received_by_id")
  refundedAmount Decimal      @default(0) @map("refunded_amount") @db.Decimal(10, 2)
  refundOfId    String?       @map("refund_of_id")
  refundReason  String?       @map("refund_reason")
  createdAt     DateTime      @default(now()) @map("created_at")

  comanda      Comanda          @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  refundOf     Payment?         @relation("PaymentRefund", fields: [refundOfId], references: [id], onDelete: Restrict)
  refunds      Payment[]        @relation("PaymentRefund")
  cashMovements CashMovement[]
  financialEntries FinancialEntry[]
  commissionAdjustments CommissionAdjustment[]

  @@unique([barbershopId, idempotencyKey])
  @@index([barbershopId, paidAt])
  @@index([comandaId])

  @@map("command_payments")
}

model CashSession {
  id             String            @id @default(uuid())
  barbershopId    String            @map("barbershop_id")
  status         CashSessionStatus @default(OPEN)
  openedById     String            @map("opened_by_id")
  openingAmount  Decimal           @map("opening_amount") @db.Decimal(10, 2)
  openedAt       DateTime          @default(now()) @map("opened_at")
  closedById     String?           @map("closed_by_id")
  closingAmount  Decimal?          @map("closing_amount") @db.Decimal(10, 2)
  expectedAmount Decimal           @default(0) @map("expected_amount") @db.Decimal(10, 2)
  difference     Decimal?          @db.Decimal(10, 2)
  closedAt       DateTime?         @map("closed_at")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  movements  CashMovement[]

  @@index([barbershopId, status])
  @@map("cash_sessions")
}

model CashMovement {
  id            String   @id @default(uuid())
  barbershopId  String   @map("barbershop_id")
  cashSessionId String   @map("cash_session_id")
  paymentId     String?  @map("payment_id")
  amount        Decimal  @db.Decimal(10, 2)
  description   String
  createdAt     DateTime @default(now()) @map("created_at")

  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  payment     Payment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([barbershopId, cashSessionId, createdAt])
  @@map("cash_movements")
}

model FinancialEntry {
  id           String             @id @default(uuid())
  barbershopId String             @map("barbershop_id")
  type         FinancialEntryType
  category     String
  amount       Decimal            @db.Decimal(10, 2)
  description  String
  entryDate    DateTime           @default(now()) @map("entry_date")
  userId       String?            @map("user_id")
  comandaId    String?            @map("comanda_id")
  paymentId    String?            @map("payment_id")
  createdAt    DateTime           @default(now()) @map("created_at")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  payment    Payment?   @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([barbershopId, entryDate])
  @@index([barbershopId, type])
  @@map("financial_entries")
}

enum CommissionConfigType {
  PERCENTAGE
  FIXED_VALUE
}

enum CommissionEntryStatus {
  GENERATED
  PARTIALLY_RELEASED
  RELEASED
  PAID
  REVERSED
}

enum CommissionPeriodStatus {
  OPEN
  CLOSED
  PAID
}

enum CommissionAdjustmentType {
  RELEASE
  REVERSAL
  PAID_ADJUSTMENT
}

model CommissionConfig {
  id           String               @id @default(uuid())
  barbershopId String               @map("barbershop_id")
  memberId     String?              @map("member_id")
  serviceId    String?              @map("service_id")
  categoryId   String?              @map("category_id")
  scopeKey     String               @map("scope_key")
  type         CommissionConfigType
  value        Decimal              @db.Decimal(10, 2)
  active       Boolean              @default(true)
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  barbershop Barbershop        @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  member     BarbershopMember? @relation(fields: [memberId], references: [id], onDelete: Cascade)
  service    Service?          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  category   Category?         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  entries    CommissionEntry[]

  @@unique([barbershopId, scopeKey])
  @@index([barbershopId, active])
  @@index([memberId])
  @@index([serviceId])
  @@index([categoryId])
  @@map("commission_configs")
}

model CommissionEntry {
  id                String                @id @default(uuid())
  barbershopId      String                @map("barbershop_id")
  comandaItemId     String                @unique @map("comanda_item_id")
  memberId          String                @map("member_id")
  configId          String?               @map("config_id")
  configSnapshot    Json                  @map("config_snapshot")
  baseAmount        Decimal               @map("base_amount") @db.Decimal(10, 2)
  generatedAmount   Decimal               @map("generated_amount") @db.Decimal(10, 2)
  releasedAmount    Decimal               @default(0) @map("released_amount") @db.Decimal(10, 2)
  paidAmount        Decimal               @default(0) @map("paid_amount") @db.Decimal(10, 2)
  reversedAmount    Decimal               @default(0) @map("reversed_amount") @db.Decimal(10, 2)
  competence        String
  status            CommissionEntryStatus @default(GENERATED)
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  barbershop  Barbershop        @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  comandaItem ComandaItem       @relation(fields: [comandaItemId], references: [id], onDelete: Cascade)
  member      BarbershopMember  @relation(fields: [memberId], references: [id], onDelete: Restrict)
  config      CommissionConfig? @relation(fields: [configId], references: [id], onDelete: SetNull)
  adjustments CommissionAdjustment[]

  @@index([barbershopId, competence])
  @@index([barbershopId, status])
  @@index([memberId, competence])
  @@map("commission_entries")
}

model CommissionPeriod {
  id              String                 @id @default(uuid())
  barbershopId    String                 @map("barbershop_id")
  memberId        String                 @map("member_id")
  competence      String
  status          CommissionPeriodStatus @default(OPEN)
  generatedAmount Decimal                @default(0) @map("generated_amount") @db.Decimal(10, 2)
  releasedAmount  Decimal                @default(0) @map("released_amount") @db.Decimal(10, 2)
  paidAmount      Decimal                @default(0) @map("paid_amount") @db.Decimal(10, 2)
  reversedAmount  Decimal                @default(0) @map("reversed_amount") @db.Decimal(10, 2)
  balanceAmount   Decimal                @default(0) @map("balance_amount") @db.Decimal(10, 2)
  closedAt        DateTime?              @map("closed_at")
  paidAt          DateTime?              @map("paid_at")
  closedById      String?                @map("closed_by_id")
  paidById        String?                @map("paid_by_id")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  barbershop Barbershop       @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  member     BarbershopMember @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@unique([barbershopId, memberId, competence])
  @@index([barbershopId, competence])
  @@index([barbershopId, status])
  @@map("commission_periods")
}

model CommissionAdjustment {
  id           String                   @id @default(uuid())
  barbershopId String                   @map("barbershop_id")
  entryId      String                   @map("entry_id")
  memberId     String                   @map("member_id")
  paymentId    String?                  @map("payment_id")
  type         CommissionAdjustmentType
  amount       Decimal                  @db.Decimal(10, 2)
  competence   String
  description  String
  createdAt    DateTime                 @default(now()) @map("created_at")

  barbershop Barbershop       @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  entry      CommissionEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  member     BarbershopMember @relation(fields: [memberId], references: [id], onDelete: Restrict)
  payment    Payment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([barbershopId, competence])
  @@index([memberId, competence])
  @@index([paymentId])
  @@map("commission_adjustments")
}
